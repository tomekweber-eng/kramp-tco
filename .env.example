# Neon Postgres connection string (Vercel → Storage → Neon ustawi to automatycznie
# w środowisku; do lokalnego `vercel dev` skopiuj tu wartość z panelu).
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --- Mailing (OPCJONALNE) ---------------------------------------------------
# Dopóki RESEND_API_KEY nie jest ustawiony, /api/lead tylko zapisuje leada
# do bazy i NIE wysyła maila. Ustaw klucz, aby aktywować wysyłkę raportu.
# Darmowy klucz: Vercel → Storage/Integrations → Resend (lub resend.com).
RESEND_API_KEY=

# Nadawca. Bez zweryfikowanej domeny w Resend zostaw domyślny testowy adres
# (wysyłka możliwa tylko na Twój własny e-mail). Do klientów: zweryfikuj domenę
# i ustaw np. "Kramp <raport@twojadomena.pl>".
REPORT_FROM=Kramp <onboarding@resend.dev>

# Opcjonalny adres, na który ma trafiać kopia każdego raportu (handlowiec/CRM).
REPORT_BCC=
